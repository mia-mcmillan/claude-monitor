{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "npm: compile",
      "type": "shell",
      "command": "npm",
      "args": ["run", "compile"],
      "problemMatcher": {
        "owner": "typescript",
        "fileLocation": "relative",
        "pattern": {
          "regexp": "^.*?\\s+(.*?)\\((\\d+),(\\d+)\\):\\s+(error|warning)\\s+(TS\\d+)\\s*:\\s*(.*)$",
          "file": 1,
          "location": "2:3",
          "message": 6
        }
      },
      "isBackground": false,
      "presentation": {
        "reveal": "silent"
      }
    }
  ]
}